@page
@model IdentityReconciliation.WebAPI.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard - Identity Reconciliation";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body {
            background-color: #f8f9fa;
        }
        .stat-card {
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            transition: transform 0.2s;
        }
        .stat-card:hover {
            transform: translateY(-5px);
        }
        .stat-card .card-body {
            padding: 1.5rem;
        }
        .stat-icon {
            font-size: 2.5rem;
            opacity: 0.8;
        }
        .stat-value {
            font-size: 2rem;
            font-weight: bold;
        }
        .stat-label {
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            opacity: 0.8;
        }
        .card-linked { background: linear-gradient(135deg, #28a745, #20c997); color: white; }
        .card-pending { background: linear-gradient(135deg, #ffc107, #ff9800); color: white; }
        .card-conflict { background: linear-gradient(135deg, #dc3545, #c82333); color: white; }
        .card-unmatched { background: linear-gradient(135deg, #6c757d, #5a6268); color: white; }
        .table-container {
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            padding: 1.5rem;
            margin-top: 1.5rem;
        }
        .nav-tabs .nav-link {
            color: #495057;
            border-radius: 8px 8px 0 0;
        }
        .nav-tabs .nav-link.active {
            font-weight: bold;
            color: #0d6efd;
        }
        .btn-action {
            padding: 0.25rem 0.5rem;
            font-size: 0.875rem;
        }
        .match-score {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-weight: bold;
            font-size: 0.85rem;
        }
        .score-high { background-color: #d4edda; color: #155724; }
        .score-medium { background-color: #fff3cd; color: #856404; }
        .score-low { background-color: #f8d7da; color: #721c24; }
        .alert-toast {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            min-width: 300px;
        }
        .header-brand {
            font-size: 1.5rem;
            font-weight: bold;
            color: #0d6efd;
        }
    </style>
</head>
<body>
    <!-- Alert Toast -->
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show alert-toast" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show alert-toast" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Header -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
        <div class="container-fluid">
            <span class="navbar-brand header-brand">
                <i class="bi bi-shield-lock me-2"></i>NBS Identity Reconciliation
            </span>
            <span class="navbar-text text-white">
                <i class="bi bi-person-circle me-1"></i>Admin Dashboard
            </span>
        </div>
    </nav>

    <div class="container-fluid px-4">
        <!-- Run Auto-Match Button -->
        <div class="row mb-4">
            <div class="col-12 d-flex justify-content-between align-items-center">
                <h4><i class="bi bi-speedometer2 me-2"></i>Dashboard Overview</h4>
                <form method="post" asp-page-handler="RunAutoMatch" class="d-inline">
                    <button type="submit" class="btn btn-primary btn-lg" onclick="return confirm('Are you sure you want to run the auto-match algorithm? This will attempt to automatically link pending records.')">
                        <i class="bi bi-play-circle me-2"></i>Run Auto-Match Now
                    </button>
                </form>
            </div>
        </div>

        <!-- Stat Cards -->
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <div class="card stat-card card-linked">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="stat-value">@Model.Stats.LinkedCount</div>
                                <div class="stat-label">Linked</div>
                            </div>
                            <i class="bi bi-check-all stat-icon"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card card-pending">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="stat-value">@Model.Stats.PendingCount</div>
                                <div class="stat-label">Pending</div>
                            </div>
                            <i class="bi bi-hourglass-split stat-icon"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card card-conflict">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="stat-value">@Model.Stats.ConflictCount</div>
                                <div class="stat-label">Conflicts</div>
                            </div>
                            <i class="bi bi-exclamation-octagon stat-icon"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card card-unmatched">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="stat-value">@Model.Stats.UnmatchedCount</div>
                                <div class="stat-label">Unmatched</div>
                            </div>
                            <i class="bi bi-person-x stat-icon"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabbed Interface -->
        <div class="table-container">
            <ul class="nav nav-tabs" id="dashboardTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="pending-tab" data-bs-toggle="tab" data-bs-target="#pending" type="button" role="tab">
                        <i class="bi bi-hourglass-split me-2"></i>Pending Matches (@Model.PendingMatches.Count)
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="conflicts-tab" data-bs-toggle="tab" data-bs-target="#conflicts" type="button" role="tab">
                        <i class="bi bi-exclamation-triangle me-2"></i>Conflicts (@Model.Conflicts.Count)
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="logs-tab" data-bs-toggle="tab" data-bs-target="#logs" type="button" role="tab">
                        <i class="bi bi-clock-history me-2"></i>Sync Logs
                    </button>
                </li>
            </ul>

            <div class="tab-content pt-4" id="dashboardTabsContent">
                <!-- Pending Matches Tab -->
                <div class="tab-pane fade show active" id="pending" role="tabpanel">
                    @if (Model.PendingMatches.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Gibbon User</th>
                                        <th>Moodle User</th>
                                        <th>IdP Username</th>
                                        <th>Email Match Score</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var match in Model.PendingMatches)
                                    {
                                        var scoreClass = match.MatchScore >= 80 ? "score-high" : (match.MatchScore >= 50 ? "score-medium" : "score-low");
                                        <tr>
                                            <td>
                                                <strong>@match.GibbonName</strong><br/>
                                                <small class="text-muted">@match.GibbonEmail</small>
                                            </td>
                                            <td>
                                                <strong>@match.MoodleName</strong><br/>
                                                <small class="text-muted">@match.MoodleEmail</small>
                                            </td>
                                            <td>@match.IdPUsername</td>
                                            <td>
                                                <span class="match-score @scoreClass">@match.MatchScore%</span>
                                            </td>
                                            <td>
                                                <form method="post" asp-page-handler="LinkUsers" class="d-inline">
                                                    <input type="hidden" name="moodleId" value="@match.MoodleId" />
                                                    <input type="hidden" name="gibbonId" value="@match.GibbonId" />
                                                    <input type="hidden" name="email" value="@match.MoodleEmail" />
                                                    <button type="submit" class="btn btn-sm btn-success btn-action" title="Link these users">
                                                        <i class="bi bi-link-45deg"></i> Link
                                                    </button>
                                                </form>
                                                <form method="post" asp-page-handler="IgnoreMatch" class="d-inline">
                                                    <input type="hidden" name="userMapId" value="@match.UserMapId" />
                                                    <button type="submit" class="btn btn-sm btn-secondary btn-action" title="Ignore this match">
                                                        <i class="bi bi-x-circle"></i> Ignore
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-check-circle display-4 text-success"></i>
                            <h5 class="mt-3">No Pending Matches</h5>
                            <p class="text-muted">All records have been processed.</p>
                        </div>
                    }
                </div>

                <!-- Conflicts Tab -->
                <div class="tab-pane fade" id="conflicts" role="tabpanel">
                    @if (Model.Conflicts.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Email</th>
                                        <th>Moodle Users</th>
                                        <th>Gibbon Candidates</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var conflict in Model.Conflicts)
                                    {
                                        <tr>
                                            <td><strong>@conflict.Email</strong></td>
                                            <td>
                                                @foreach (var m in conflict.MoodleCandidates)
                                                {
                                                    <div>@m.Firstname @m.Lastname<br/><small class="text-muted">@m.Username</small></div>
                                                }
                                            </td>
                                            <td>
                                                @foreach (var g in conflict.GibbonCandidates)
                                                {
                                                    <div>@g.OfficialName<br/><small class="text-muted">ID: @g.GibbonPersonId</small></div>
                                                }
                                            </td>
                                            <td>
                                                <span class="text-warning"><i class="bi bi-exclamation-triangle me-1"></i>Review Required</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-check-circle display-4 text-success"></i>
                            <h5 class="mt-3">No Conflicts</h5>
                            <p class="text-muted">All conflicts have been resolved.</p>
                        </div>
                    }
                </div>

                <!-- Sync Logs Tab -->
                <div class="tab-pane fade" id="logs" role="tabpanel">
                    @if (Model.SyncLogs.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Action</th>
                                        <th>Details</th>
                                        <th>Timestamp</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var log in Model.SyncLogs)
                                    {
                                        <tr>
                                            <td>
                                                @if (log.Action == "Linked")
                                                {
                                                    <span class="badge bg-success"><i class="bi bi-check me-1"></i>@log.Action</span>
                                                }
                                                else if (log.Action == "Conflict")
                                                {
                                                    <span class="badge bg-danger"><i class="bi bi-exclamation me-1"></i>@log.Action</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">@log.Action</span>
                                                }
                                            </td>
                                            <td>@log.Details</td>
                                            <td>@log.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-clock display-4 text-muted"></i>
                            <h5 class="mt-3">No Recent Activity</h5>
                            <p class="text-muted">Sync logs will appear here after reconciliation operations.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Auto-hide alerts after 5 seconds
        setTimeout(function() {
            var alerts = document.querySelectorAll('.alert-toast');
            alerts.forEach(function(alert) {
                var bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);
    </script>
</body>
</html>
